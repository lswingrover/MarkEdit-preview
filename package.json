{
  "name": "markedit-preview",
  "version": "1.7.1",
  "description": "Markdown preview for MarkEdit.",
  "scripts": {
    "test": "vitest run",
    "lint": "eslint . --config eslint.config.mjs",
    "build": "yarn lint && vite build && rm -f ~/Library/Group\\ Containers/group.app.cyan.markedit/Shared/scripts/$(node -p \"require('./package.json').name\").js",
    "build:lite": "cross-env LITE_BUILD=true vite build",
    "reload": "osascript -e 'quit app \"MarkEdit\"' -e 'delay 1' -e 'launch app \"MarkEdit\"'",
    "uninstall": "rm ~/Library/Containers/app.cyan.markedit/Data/Documents/scripts/$(node -p \"require('./package.json').name\").js"
  },
  "license": "MIT",
  "devDependencies": {
    "@codemirror/language": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@lezer/markdown": "^1.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/markdown-it-link-attributes": "^3.0.5",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
    "eslint": "^9.27.0",
    "happy-dom": "^20.8.9",
    "markedit-api": "https://github.com/MarkEdit-app/MarkEdit-api#v0.26.0",
    "markedit-vite": "https://github.com/MarkEdit-app/MarkEdit-vite#v0.4.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vite-plugin-singlefile": "^2.2.0",
    "vitest": "^4.0.18",
    "@types/turndown": "^5.0.5"
  },
  "dependencies": {
    "js-yaml": "^4.2.0",
    "katex": "^0.17.0",
    "mark.js": "^8.11.1",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-front-matter": "^0.2.4",
    "markdown-it-github-alerts": "^1.0.1",
    "markdown-it-highlightjs": "^4.3.0",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-task-lists": "^2.1.1",
    "markedit-katex": "https://github.com/MarkEdit-app/MarkEdit-katex#v1.1.5",
    "mermaid": "^11.15.0",
    "split-grid": "^1.0.11",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
